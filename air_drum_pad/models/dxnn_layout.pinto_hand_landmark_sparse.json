{
  "input": {
    "tensor_name": "input",
    "tensor_layout": "nhwc",
    "color_order": "rgb",
    "square_pad": true,
    "normalize": {
      "mode": "none",
      "dtype": "uint8"
    }
  },
  "inference": {
    "dual_horizontal_halves": false
  },
  "outputs": {
    "landmarks_tensor_index": 0,
    "coordinate_space": "letterbox_patch_pixels",
    "points_per_hand": 21,
    "max_hands": 1
  },
  "handedness": {
    "mode": "tensor_binary",
    "tensor_index": 2,
    "threshold": 0.5,
    "left_label": "Left",
    "right_label": "Right"
  },
  "confidence": {
    "tensor_index": 1,
    "threshold": 0.5
  }
}
